# =====================================================================
# NIDS Backend Environment Configuration (Template)
# =====================================================================

# --------------------------
# General Configuration
# --------------------------
APP_ENV=development
PROJECT_NAME="CodeAlpha NIDS API"
VERSION="1.0.0"

# --------------------------
# Database
# --------------------------
DATABASE_URL=sqlite+aiosqlite:///./nids_dev.db

# --------------------------
# Security & Auth
# --------------------------
JWT_SECRET_KEY=dummy_secret_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --------------------------
# Suricata Integration
# --------------------------
EVE_LOG_PATH=/var/log/suricata/eve.json

# --------------------------
# Threat Intelligence & GeoIP
# --------------------------
ABUSEIPDB_API_KEY=dummy_abuseipdb_key_replace_me
VIRUSTOTAL_API_KEY=dummy_virustotal_key_replace_me
GEOIP_DB_PATH=./suricata/data/GeoLite2-City.mmdb

# --------------------------
# Response Engine & Notifications
# --------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/DUMMY/WEBHOOK/URL
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dummy_email@gmail.com
SMTP_PASSWORD=dummy_smtp_password_replace_me
SMTP_FROM_EMAIL=nids-alerts@nids.local
