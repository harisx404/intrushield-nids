# ============================================================
# NIDS-Pro Backend Configuration
# Copy to .env and fill in real values before running.
# NEVER commit the real .env file to git.
# ============================================================

# Application
APP_NAME=NIDS-Pro
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Security — CHANGE THESE IN PRODUCTION
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_256_BIT_RANDOM_HEX_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# Development: SQLite (zero config)
DATABASE_URL=sqlite+aiosqlite:///./database/nids.db
# Production: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://nids_user:password@localhost:5432/nids

# Demo seeding — when true, an idempotent admin user + sample alerts are
# created on startup so a fresh `docker compose up` has a working login.
# Default admin: admin / changeme123 (see README "First login"). Set false
# in real deployments and create users with scripts/create_user.py instead.
SEED_DEMO_USER=true


# Suricata
SURICATA_LOG_PATH=/var/log/suricata/eve.json
SURICATA_CONFIG_PATH=/etc/suricata/suricata.yaml
SURICATA_RULES_PATH=/etc/suricata/rules/custom.rules
SURICATA_BINARY=suricata

# GeoIP (Download free GeoLite2-City.mmdb from MaxMind — requires free account)
GEOIP_DB_PATH=/opt/geoip/GeoLite2-City.mmdb

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Response Engine ──────────────────────────────────────────────
ENABLE_LOG_RESPONSE=true

ENABLE_EMAIL_RESPONSE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
EMAIL_MIN_SEVERITY=HIGH

ENABLE_WEBHOOK_RESPONSE=false
WEBHOOK_URL=
WEBHOOK_MIN_SEVERITY=MEDIUM

ENABLE_FIREWALL_RESPONSE=false
ENABLE_IP_BLOCK_RESPONSE=false
IP_BLOCK_THRESHOLD_COUNT=5
IP_BLOCK_THRESHOLD_MINUTES=5
IP_BLOCK_DURATION_HOURS=24
