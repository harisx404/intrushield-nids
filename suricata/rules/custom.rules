# NIDS Custom Suricata Rules for IntruShield NIDS
# Author: Muhammad Haris (@harisx404) | Lead Security Engineer
# Contact: itsharis.tech@gmail.com | LinkedIn: https://linkedin.com/in/harisx404
# ==============================================================================

# 1. SSH Brute Force Detection (Thresholding)
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"SSH Brute Force Attempt"; flow:established,to_server; content:"SSH-"; depth:4; threshold:type limit, track by_src, count 5, seconds 60; classtype:attempted-login; sid:1000001; rev:1;)

# 2. SQL Injection (Generic OR 1=1 payload)
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"Possible SQL Injection (OR 1=1)"; flow:established,to_server; content:"' OR 1=1"; http_uri; nocase; classtype:web-application-attack; sid:1000002; rev:1;)

# 3. SQL Injection (UNION SELECT payload)
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"Possible SQL Injection (UNION SELECT)"; flow:established,to_server; content:"UNION"; http_uri; nocase; content:"SELECT"; http_uri; nocase; distance:0; classtype:web-application-attack; sid:1000003; rev:1;)

# 4. Nmap OS Detection Probe
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"Nmap OS Detection Probe"; flags:A,U,P,S,F; classtype:network-scan; sid:1000004; rev:1;)

# 5. Log4Shell (CVE-2021-44228) JNDI Lookup Attempt
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"Log4Shell JNDI Injection Attempt"; flow:established,to_server; content:"${jndi:"; nocase; classtype:attempted-admin; sid:1000005; rev:1;)

# 6. Basic XSS (Cross-Site Scripting) Probe
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"Possible XSS Attempt"; flow:established,to_server; content:"<script>"; http_uri; nocase; classtype:web-application-attack; sid:1000006; rev:1;)

# 7. Reverse Shell Detection (Generic /bin/bash)
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"Possible Reverse Shell (/bin/bash outbound)"; flow:established,to_server; content:"/bin/bash -i"; nocase; classtype:suspicious-login; sid:1000007; rev:1;)

# 8. DNS Exfiltration (Large TXT Records)
alert dns $HOME_NET any -> any 53 (msg:"Suspicious Large DNS TXT Query"; content:"|00 10|"; offset:2; depth:2; dsize:>200; classtype:bad-unknown; sid:1000008; rev:1;)

# 9. ICMP Ping Sweep (Thresholding)
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"ICMP Ping Sweep Detected"; itype:8; threshold:type both, track by_src, count 10, seconds 10; classtype:network-scan; sid:1000009; rev:1;)

# 10. Web Directory Traversal (/etc/passwd)
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"Directory Traversal Attempt (/etc/passwd)"; flow:established,to_server; content:"/etc/passwd"; http_uri; nocase; classtype:attempted-recon; sid:1000010; rev:1;)
